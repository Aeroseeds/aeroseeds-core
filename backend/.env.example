PORT=4000
INFERENCE_SERVICE_URL=http://localhost:8000

# OpenRouter is used both as a pre-check vision gate (reject unusable
# photos before they reach the inference service) and as a cross-examiner
# that confirms or contradicts the CNN's diagnosis. It never names a
# disease itself.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here
# Comma-separated, in fallback order: each is tried in turn, moving to the
# next only if a call errors, times out (10s), or is rate-limited. If every
# model fails, the backend logs it and skips the gate (or falls back to the
# CNN-only result for cross-exam) rather than blocking the user. Leave
# unset to use the built-in default chain (see config.js).
OPENROUTER_VISION_MODELS=google/gemini-2.5-flash,openai/gpt-4o,anthropic/claude-sonnet-4.6,qwen/qwen2.5-vl-72b-instruct,mistralai/mistral-large-2512,meta-llama/llama-4-maverick,x-ai/grok-4.3

# After a confident diagnosis, these models fetch current, Nigeria-specific
# treatment product recommendations grounded in a live web search (OpenRouter
# "web" plugin). Same fallback-chain behaviour as the vision models. Results
# are cached per disease for 7 days, so this fires at most once per disease
# per week -- not once per scan. Leave unset to use the built-in default chain.
OPENROUTER_ADVISOR_MODELS=google/gemini-2.5-flash,openai/gpt-4o,anthropic/claude-sonnet-4.6

# Minimum CNN confidence (0-1) required to attempt cross-examination.
# Below this, the backend returns an "uncertain" status instead.
CONFIDENCE_THRESHOLD=0.65

# How many images from a /diagnose-batch request are processed concurrently.
# Keeps large batches from firing hundreds of simultaneous OpenRouter calls.
BATCH_CONCURRENCY=6
